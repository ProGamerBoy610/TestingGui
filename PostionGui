local function updateBestESP()
    if bestESP then
        if bestESP.Highlight then bestESP.Highlight:Destroy() end
        if bestESP.Billboard then bestESP.Billboard:Destroy() end
        bestESP=nil
    end
    local b = findBestBrainrot(nil)
    if not b or not b.Model then return end
    bestESP = createESP(b.Model, "BEST BRAINROT\n"..b.Rate.."\n["..b.Rarity.."]", Color3.fromRGB(255,215,0), b.TimeLeft)

    local changed = not state.lastBest or state.lastBest.RateValue~=b.RateValue or state.lastBest.Rarity~=b.Rarity
    if changed and state.bestWebhook~="" then
        state.lastBest=b
        task.spawn(function()
            local gameName = pcall(function() return game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name end) and "Server" or "Server"
            sendWebhook(state.bestWebhook,
                "🏆 **MELHOR BRAINROT ATUALIZADO!**\n\n💎 **Raridade:** "..b.Rarity..
                "\n💰 **Rate:** "..b.Rate.."\n⏰ **Time Left:** "..b.TimeLeft)
        end)
    end
    return b
end

