-- Step 1: Check if someone hooked getfenv to spy on your script
local function check_getfenv_hook()
    if getfenv ~= nil then
        local t = type(getfenv)
        if t ~= "function" then
            _SAFE = false
            _REASON = "getfenv is not a function — someone replaced it"
            return
        end

        local ok, fenv = pcall(getfenv, 0)
        if not ok then
            _SAFE = false
            _REASON = "getfenv(0) threw an error — likely hooked by another script"
            return
        end
    end
end

-- Step 2: Check if _G has been wrapped in a metatable to spy on your variables
local function check_env_proxy()
    local mt = getmetatable(_G)
    if mt ~= nil then
        -- Check if the metatable has __index or __newindex (spying methods)
        if mt.__index or mt.__newindex then
            _SAFE = false
            _REASON = "_G has a metatable with hooks — someone is monitoring your script"
            return
        end
    end
end

-- Step 3: Check for leaked environment variables that indicate tampering
local function check_fenv_leak()
    local suspicious_keys = {
        "fenv", "env", "_fenv", "__fenv",
        "genv", "globalenv", "_env", "rawenv",
        "hookenv", "scriptenv", "stolen_env"
    }
    
    for _, key in ipairs(suspicious_keys) do
        if rawget(_G, key) ~= nil then
            _SAFE = false
            _REASON = "Suspicious variable found in _G: '" .. key .. "' — possible theft attempt"
            return
        end
    end
end

-- Step 4: Check if someone used setfenv to hijack your script's environment
local function check_setfenv_swap()
    if setfenv and getfenv then
        local ok, my_env = pcall(getfenv, check_setfenv_swap)
        if ok and type(my_env) == "table" then
            -- Check if critical functions are still present
            if my_env.print == nil or my_env.warn == nil then
                _SAFE = false
                _REASON = "setfenv was used to swap environment — core functions missing"
                return
            end
        end
    end
end

-- Step 5: Detect if debug library is being used to modify your script's upvalues
local function check_debug_upvalue_injection()
    if debug and debug.getupvalue then
        local i = 1
        while true do
            local ok, name, val = pcall(debug.getupvalue, check_debug_upvalue_injection, i)
            if not ok or name == nil then break end
            
            if name == "_SAFE" and val == false then
                _REASON = "Upvalue '_SAFE' was modified — debug library used to tamper"
                return
            end
            i = i + 1
        end
    end
end

-- Step 6: Check if common script-stealing methods are present
local function check_script_stealing()
    -- Check if someone is trying to dump/copy your script
    local stealing_functions = {
        "decompile", "getscriptbytecode", "getscripthash",
        "dumpstring", "saveinstance"
    }
    
    for _, func_name in ipairs(stealing_functions) do
        if _G[func_name] ~= nil or getfenv(0)[func_name] ~= nil then
            _SAFE = false
            _REASON = "Script stealing function detected: '" .. func_name .. "'"
            return
        end
    end
end

