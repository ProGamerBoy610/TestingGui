local function getFishName(fish)
    local ok, result = pcall(function() return fish.Head.stats.Fish.Text end)
    return ok and result or "Unknown Fish"
end

local function getFishMutation(fish)
    local ok, result = pcall(function() return fish.Head.stats.Mutation.Label.Text end)
    return ok and result or ""
end

local function getChestColor(tier)
    if tier == "Tier 3" then
        return CONFIG_ESP.Colors.ChestT3
    elseif tier == "Tier 2" then
        return CONFIG_ESP.Colors.ChestT2
    else
        return CONFIG_ESP.Colors.ChestT1
    end
end

