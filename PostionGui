local _SAFE = true
local _REASON = ""

-- ⚙️ CONFIGURATION
local WEBHOOK_URL = "YOUR_DISCORD_WEBHOOK_URL_HERE" -- Replace with your Discord webhook URL
local KICK_MESSAGE = "You have been kicked for suspicious activity.\nReason: Injection detected."

-- Detect environment
local IS_ROBLOX = game ~= nil and typeof ~= nil
local IS_STUDIO = IS_ROBLOX and game:GetService("RunService"):IsStudio()

-- Function to get HWID (Hardware ID) in Roblox
local function get_hwid()
    if not IS_ROBLOX then return "N/A" end
    local HttpService = game:GetService("HttpService")
    local player = game:GetService("Players").LocalPlayer
    local hwid = HttpService:GenerateGUID(false)
    return hwid
end

-- Function to send data to Discord webhook
local function send_to_webhook(player_name, hwid, reason)
    if not IS_ROBLOX then return end
    if IS_STUDIO then return end -- Skip webhook in Studio
    
    local HttpService = game:GetService("HttpService")
    
    local embed = {
        ["embeds"] = {{
            ["title"] = "🚨 Executor Detected",
            ["color"] = 16711680, -- Red color
            ["fields"] = {
                {
                    ["name"] = "Player Name",
                    ["value"] = player_name,
                    ["inline"] = true
                },
                {
                    ["name"] = "User ID",
                    ["value"] = tostring(game.Players.LocalPlayer.UserId),
                    ["inline"] = true
                },
                {
                    ["name"] = "HWID",
                    ["value"] = hwid,
                    ["inline"] = false
                },
                {
                    ["name"] = "Detection Reason",
                    ["value"] = "```" .. reason .. "```",
                    ["inline"] = false
                },
                {
                    ["name"] = "Game",
                    ["value"] = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name,
                    ["inline"] = true
                },
                {
                    ["name"] = "Place ID",
                    ["value"] = tostring(game.PlaceId),
                    ["inline"] = true
                },
                {
                    ["name"] = "Timestamp",
                    ["value"] = os.date("%Y-%m-%d %H:%M:%S"),
                    ["inline"] = false
                }
            },
            ["footer"] = {
                ["text"] = "Anti-Cheat System"
            },
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%S")
        }}
    }
    
    local success, err = pcall(function()
        HttpService:PostAsync(
            WEBHOOK_URL,
            HttpService:JSONEncode(embed),
            Enum.HttpContentType.ApplicationJson,
            false
        )
    end)
    
    if not success then
        warn("[Security] Failed to send webhook: " .. tostring(err))
    end
end

-- Function to kick player
local function kick_player(reason)
    if not IS_ROBLOX then return end
    if IS_STUDIO then return end -- Don't kick in Studio
    
    local player = game:GetService("Players").LocalPlayer
    if player then
        player:Kick(KICK_MESSAGE .. "\n\nTechnical Details: " .. reason)
    end
end

-- Step 1: Check if getfenv exists and has been called already
local function check_getfenv_hook()
    if getfenv ~= nil then
        local t = type(getfenv)
        if t ~= "function" then
            _SAFE = false
            _REASON = "getfenv is not a function — it's a " .. t .. " (spoofed)"
            return
        end

        local ok, fenv = pcall(getfenv, 0)
        if not ok then
            _SAFE = false
            _REASON = "getfenv(0) threw an error — likely hooked"
            return
        end

        if IS_ROBLOX then
            if fenv.game == nil or fenv.workspace == nil then
                _SAFE = false
                _REASON = "Roblox environment missing core globals — possibly spoofed"
                return
            end
            
            if fenv.getfenv ~= getfenv then
                _SAFE = false
                _REASON = "getfenv function was replaced in environment"
                return
            end
        else
            if fenv ~= _G then
                _SAFE = false
                _REASON = "getfenv(0) returned a different table than _G — environment proxied/sandboxed"
                return
            end
        end

        local ok2, fenv1 = pcall(getfenv, 1)
        if ok2 then
            if IS_ROBLOX then
                if type(fenv1) ~= "table" then
                    _SAFE = false
                    _REASON = "getfenv(1) didn't return a table"
                    return
                end
            else
                if fenv1 ~= _G then
                    _SAFE = false
                    _REASON = "getfenv(1) returned a sandboxed environment — injection detected"
                    return
                end
            end
        end
    end
end

local function check_env_proxy()
    local mt = getmetatable(_G)
    if mt ~= nil then
        if IS_ROBLOX then
            local test_ok = pcall(function()
                local old = _G._TEST_WRITE_CHECK
                _G._TEST_WRITE_CHECK = true
                _G._TEST_WRITE_CHECK = old
            end)
            if not test_ok then
                return
            end
        end
        
        _SAFE = false
        _REASON = "_G has a suspicious metatable — environment is proxied"
        return
    end
end

local function check_fenv_leak()
    local suspicious_keys = {
        "fenv", "env", "_fenv", "__fenv",
        "genv", "globalenv", "_env", "rawenv",
        "hookenv", "scriptenv"
    }
    for _, key in ipairs(suspicious_keys) do
        if rawget(_G, key) ~= nil then
            _SAFE = false
            _REASON = "Suspicious environment variable found in _G: '" .. key .. "'"
            return
        end
    end
end

local function check_bytecode_integrity()
    if string and string.dump then
        local ok, dump = pcall(string.dump, check_bytecode_integrity)
        if not ok then
            if not IS_ROBLOX then
                _SAFE = false
                _REASON = "string.dump failed — bytecode may be obfuscated or hooked"
            end
            return
        end
        
        if type(dump) == "string" and #dump < 10 then
            _SAFE = false
            _REASON = "Bytecode dump suspiciously small — possible hook"
            return
        end
    end
end

local function check_setfenv_swap()
    if setfenv and getfenv then
        local ok, my_env = pcall(getfenv, check_setfenv_swap)
        if ok then
            if IS_ROBLOX then
                if type(my_env) ~= "table" then
                    _SAFE = false
                    _REASON = "Function environment is not a table"
                    return
                end
            else
                if my_env ~= _G then
                    _SAFE = false
                    _REASON = "setfenv was used to swap this function's environment"
                    return
                end
            end
        end
    end
end

local function check_debug_upvalue_injection()
    if debug and debug.getupvalue then
        local i = 1
        while true do
            local ok, name, val = pcall(debug.getupvalue, check_debug_upvalue_injection, i)
            if not ok or name == nil then break end
            
            if name == "_SAFE" and val == false then
                _REASON = "Upvalue '_SAFE' was set to false externally before check"
            end
            i = i + 1
        end
    end
end

-- 🔥 MAIN EXECUTOR DETECTION - Detects Delta, KRNL, Synapse, etc.
local function check_exploit_functions()
    if not IS_ROBLOX then return end
    if IS_STUDIO then return end -- Skip executor checks in Studio
    
    -- Common exploit function names used by executors
    local exploit_functions = {
        -- Hook functions
        "hookfunction", "hookmetamethod", "getrawmetatable",
        "setreadonly", "isreadonly", "islclosure", "newcclosure",
        "hookfunc", "replaceclosure", "clonefunction",
        
        -- Environment functions
        "getgc", "getgenv", "getrenv", "getsenv",
        "getloadedmodules", "getcallingscript", "checkcaller",
        
        -- Script/Instance functions
        "getconnections", "firesignal", "fireclickdetector",
        "fireproximityprompt", "getinstances", "getnilinstances",
        
        -- Misc exploit functions
        "saveinstance", "Drawing", "WebSocket",
        "readfile", "writefile", "appendfile", "loadfile",
        "request", "http_request", "syn_request",
        
        -- Executor-specific globals
        "syn", "KRNL_LOADED", "SENTINEL_V2", "OXYGEN_LOADED",
        "WRD_LOADED", "is_sirhurt_closure", "Fluxus", 
        "Delta", "pebc_execute", "EVON_LOADED", "Arceus",
        "PROTOSMASHER_LOADED", "ScriptWare"
    }
    
    for _, func_name in ipairs(exploit_functions) do
        -- Check both _G and current environment
        if _G[func_name] ~= nil then
            _SAFE = false
            _REASON = "Executor function detected in _G: '" .. func_name .. "'"
            return
        end
        
        local env = getfenv(0)
        if env[func_name] ~= nil then
            _SAFE = false
            _REASON = "Executor function detected: '" .. func_name .. "'"
            return
        end
    end
end

