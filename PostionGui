local function parseMoney(text)
    if not text then return 0 end
    text = text:lower():gsub("%$", ""):gsub(",", "")
    local num, suf = text:match("([%d%.]+)(%a*)")
    num = tonumber(num)
    if not num then return 0 end
    return num * (suffixes[suf] or 1)
end
