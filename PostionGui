-- ==================== GIFT SPAWNER SYSTEM ====================

local connections = {}
local originalFunctions = {}
local hookedPrompts = {}
local savedTool = nil
local activeTargets = {}
local holdConnections = {}

local X_ROTATION = 75
local Y_ROTATION = 90
local Z_ROTATION = 0
local HOLD_DELAY = 0

local function setArmPose(rightShoulder)
    if not rightShoulder or not rightShoulder.Parent then return end
    rightShoulder.C0 = CFrame.new(1, 0.5, 0) * CFrame.Angles(
        math.rad(X_ROTATION),
        math.rad(Y_ROTATION),
        math.rad(Z_ROTATION)
    )
end

local function saveToolModel(tool)
    if not tool then return nil end
    local toolClone = tool:Clone()
    local tempStorage = ReplicatedStorage:FindFirstChild("TempToolStorage")
    if not tempStorage then
        tempStorage = Instance.new("Folder")
        tempStorage.Name = "TempToolStorage"
        tempStorage.Parent = ReplicatedStorage
    end
    tempStorage:ClearAllChildren()
    toolClone.Parent = tempStorage
    return toolClone
end

local function equipSavedToolToTarget(savedTool, targetChar, targetPlayer)
    if not savedTool or not targetChar then return nil end
    local targetName = targetPlayer.Name

    local giftedFolder = workspace:FindFirstChild("Gifted")
    if not giftedFolder then
        giftedFolder = Instance.new("Folder")
        giftedFolder.Name = "Gifted"
        giftedFolder.Parent = workspace
    end

    local playerFolder = giftedFolder:FindFirstChild(targetName)
    if not playerFolder then
        playerFolder = Instance.new("Folder")
        playerFolder.Name = targetName
        playerFolder.Parent = giftedFolder
    else
        playerFolder:ClearAllChildren()
    end

    if activeTargets[targetName] and activeTargets[targetName].container then
        activeTargets[targetName].container:Destroy()
    end

    local toolClone = savedTool:Clone()
    local torso = targetChar:FindFirstChild("Torso")
    local targetRightArm = targetChar:FindFirstChild("Right Arm")

    if not torso or not targetRightArm then
        toolClone:Destroy()
        return nil
    end

    local handle = toolClone:FindFirstChild("Handle")
    if not handle then
        toolClone:Destroy()
        return nil
    end

    for _, child in pairs(toolClone:GetChildren()) do
        child.Parent = playerFolder
    end
    toolClone:Destroy()

    handle = playerFolder:FindFirstChild("Handle")
    if not handle then return nil end

    for _, part in pairs(playerFolder:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
            part.Anchored = false
            part.Massless = true
        end
    end

    for _, child in pairs(handle:GetChildren()) do
        if child:IsA("Weld") or child:IsA("Motor6D") then
            child:Destroy()
        end
    end

    local weld = Instance.new("Weld")
    weld.Name = "GiftedWeld"
    weld.Part0 = handle
    weld.Part1 = targetRightArm
    weld.C0 = CFrame.new(0, 0, 0)
    weld.C1 = CFrame.new(0, -1, 0) * CFrame.Angles(math.rad(-90), 0, 0)
    weld.Parent = handle

    return playerFolder
end

local function setupVisualHold(targetPlayer, targetChar, savedTool)
    local targetName = targetPlayer.Name
    local torso = targetChar:FindFirstChild("Torso")
    if not torso then return false end

    local rightShoulder = torso:FindFirstChild("Right Shoulder")
    local rightArm = targetChar:FindFirstChild("Right Arm")

    if not rightShoulder or not rightArm then return false end

    if HOLD_DELAY > 0 then
        task.wait(HOLD_DELAY)
    end

    setArmPose(rightShoulder)

    local giftedContainer = equipSavedToolToTarget(savedTool, targetChar, targetPlayer)
    if not giftedContainer then return false end

    if not activeTargets[targetName] then
        activeTargets[targetName] = {}
    end

    activeTargets[targetName].player = targetPlayer
    activeTargets[targetName].character = targetChar
    activeTargets[targetName].rightShoulder = rightShoulder
    activeTargets[targetName].rightArm = rightArm
    activeTargets[targetName].container = giftedContainer
    activeTargets[targetName].torso = torso

    if holdConnections[targetName] then
        holdConnections[targetName]:Disconnect()
    end

    holdConnections[targetName] = RunService.RenderStepped:Connect(function()
        if not targetChar or not targetChar.Parent then
            if holdConnections[targetName] then
                holdConnections[targetName]:Disconnect()
                holdConnections[targetName] = nil
            end
            if activeTargets[targetName] then
                if activeTargets[targetName].container then
                    activeTargets[targetName].container:Destroy()
                end
                activeTargets[targetName] = nil
            end
            return
        end

        if rightShoulder and rightShoulder.Parent and torso and torso.Parent then
            rightShoulder.C0 = CFrame.new(1, 0.5, 0) * CFrame.Angles(
                math.rad(X_ROTATION),
                math.rad(Y_ROTATION),
                math.rad(Z_ROTATION)
            )
        end

        if giftedContainer and not giftedContainer.Parent then
            if holdConnections[targetName] then
                holdConnections[targetName]:Disconnect()
                holdConnections[targetName] = nil
            end
            activeTargets[targetName] = nil
        end
    end)

    targetPlayer.CharacterAdded:Connect(function(newChar)
        if holdConnections[targetName] then
            holdConnections[targetName]:Disconnect()
            holdConnections[targetName] = nil
        end
        if activeTargets[targetName] and activeTargets[targetName].container then
            activeTargets[targetName].container:Destroy()
        end
        activeTargets[targetName] = nil
    end)

    return true
end

local function cleanupAllVisualHolds()
    for targetName, data in pairs(activeTargets) do
        if data.container then
            data.container:Destroy()
        end
        if data.rightShoulder and data.rightShoulder.Parent then
            data.rightShoulder.C0 = CFrame.new(1, 0.5, 0)
        end
    end

    for targetName, connection in pairs(holdConnections) do
        if connection then
            connection:Disconnect()
        end
    end

    activeTargets = {}
    holdConnections = {}

    local giftedFolder = workspace:FindFirstChild("Gifted")
    if giftedFolder then
        giftedFolder:ClearAllChildren()
    end

    local tempStorage = ReplicatedStorage:FindFirstChild("TempToolStorage")
    if tempStorage then
        tempStorage:ClearAllChildren()
    end
end

