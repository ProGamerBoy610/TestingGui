local scaleInput, scaleMethods = settingTab.AddTextInput(
    "SetScale",
    "Set GUI Scale:",
    "0.933",
    nil,
    function(value)
        local numValue = tonumber(value)
        if numValue then
            -- Set minimum dan maksimum nilai
            local minScale = 0.6
            local maxScale = 1.1
            
            -- Validasi range
            if numValue < minScale then
                numValue = minScale
                ModernGUILibrary.createNotification("Value too low! Set to minimum: " .. minScale, "warning")
            elseif numValue > maxScale then
                numValue = maxScale
                ModernGUILibrary.createNotification("Value too high! Set to maximum: " .. maxScale, "warning")
            end
            
            -- Mengatur scale dan reposisi GUI
            
            local modernGUI = player.PlayerGui.ModernGUI
            local guiScale = modernGUI.GuiScale
            
            -- Set scale baru
            guiScale.Scale = numValue
            
            -- Reposisi GUI ke tengah (seperti baru di-spawn)
            if modernGUI:FindFirstChild("Frame") or modernGUI:FindFirstChild("MainFrame") then
                local mainFrame = modernGUI:FindFirstChild("Frame") or modernGUI:FindFirstChild("MainFrame")
                if mainFrame then
                    -- Reset posisi ke tengah layar
                    mainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
                    mainFrame.AnchorPoint = Vector2.new(0.5, 0.5)
                end
            end
            
            ModernGUILibrary.createNotification("GUI Scale set to: " .. numValue .. " and repositioned to center", "info")
        else
            ModernGUILibrary.createNotification("Invalid input! Please enter a number between 0.5 and 2.0.", "error")
        end
    end
)

