TabCombat.AddCheckbox("StandardESP", "Player ESP (Name, Distance, Health)", nil, function(checked)
    espEnabled = checked
    if checked then
        -- Highlight-based basic ESP
        local teamCheck   = true
        local espColor     = Color3.fromRGB(255, 0, 0)
        local espColorTeam = Color3.fromRGB(0, 255, 0)

        local function createHighlightESP(character)
            if character:FindFirstChild("ESPHighlight") then return end
            local highlight = Instance.new("Highlight")
            highlight.Name               = "ESPHighlight"
            highlight.FillTransparency   = 0.5
            highlight.OutlineTransparency = 0
            highlight.OutlineColor       = espColor
            highlight.FillColor          = espColor
            highlight.Adornee            = character
            highlight.Parent             = character
        end

        local function removeHighlightESP(character)
            local h = character:FindFirstChild("ESPHighlight")
            if h then h:Destroy() end
        end

        local function updateHighlightESP(targetPl)
            if not targetPl.Character then return end
            local h = targetPl.Character:FindFirstChild("ESPHighlight")
            if not h then return end
            if teamCheck and targetPl.Team == LocalPlayer.Team then
                h.FillColor = espColorTeam  h.OutlineColor = espColorTeam
            else
                h.FillColor = espColor  h.OutlineColor = espColor
            end
        end

        local function removeAllHighlightESP()
            for _, p in pairs(Players:GetPlayers()) do
                if p.Character then removeHighlightESP(p.Character) end
            end
        end

        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                if p.Character then createHighlightESP(p.Character) updateHighlightESP(p) end
                local c = p.CharacterAdded:Connect(function(char) wait(0.5) createHighlightESP(char) updateHighlightESP(p) end)
                table.insert(basicEspConnections, c)
            end
        end

        local pa = Players.PlayerAdded:Connect(function(p)
            local c = p.CharacterAdded:Connect(function(char) wait(0.5) if p ~= LocalPlayer then createHighlightESP(char) updateHighlightESP(p) end end)
            table.insert(basicEspConnections, c)
        end)
        table.insert(basicEspConnections, pa)

        local hb = RunService.Heartbeat:Connect(function()
            for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then updateHighlightESP(p) end end
        end)
        table.insert(basicEspConnections, hb)

        local pr = Players.PlayerRemoving:Connect(function(p)
            if p.Character then removeHighlightESP(p.Character) end
        end)
        table.insert(basicEspConnections, pr)

        -- Also bind Drawing-based ESP
        for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then createESP(p) end end
        RunService:BindToRenderStep("UpdateESP", Enum.RenderPriority.Camera.Value + 1, updateESP)

        ModernGUI.createNotification("ESP Enabled", "success")
    else
        for _, conn in pairs(basicEspConnections) do conn:Disconnect() end
        basicEspConnections = {}
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character then
                local h = p.Character:FindFirstChild("ESPHighlight")
                if h then h:Destroy() end
            end
        end
        RunService:UnbindFromRenderStep("UpdateESP")
        for p, _ in pairs(ESPObjects) do removeESP(p) end
        ModernGUI.createNotification("ESP Disabled", "warning")
    end
end)

TabCombat.AddLabel("WallESPTitle", "-- ESP (Wall Check) --", nil, {
