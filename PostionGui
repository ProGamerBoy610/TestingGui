local function findBestBrainrot(targetRarity)
    local ab = workspace:FindFirstChild("ActiveBrainrots") if not ab then return end
    local best, bestRate = nil, 0

    local function checkRB(rb, rarity)
        local model = nil
        for _, o in pairs(rb:GetChildren()) do if o:IsA("Model") then model=o break end end
        if not model then return end
        local rt = getRate(rb) if not rt then return end
        local rv = parseRate(rt)
        if rv > bestRate then
            bestRate=rv
            best={Model=model,RenderedBrainrot=rb,Rate=rt,Rarity=rarity,RateValue=rv,TimeLeft=getTimeLeft(rb)}
        end
    end

    if targetRarity and targetRarity~="All" then
        if targetRarity=="Divine" then
            for _, rb in pairs(ab:GetDescendants()) do
                if rb.Name=="RenderedBrainrot" and isDivine(rb) then checkRB(rb,"Divine") end
            end
        else
            local f = ab:FindFirstChild(targetRarity)
            if f then for _, rb in pairs(f:GetChildren()) do if rb.Name=="RenderedBrainrot" then checkRB(rb,targetRarity) end end end
        end
        return best
    end

    for _, rf in pairs(ab:GetChildren()) do
        local rn = rf.Name
        if next(state.selectedTypes)==nil or state.selectedTypes[rn] then
            for _, rb in pairs(rf:GetChildren()) do if rb.Name=="RenderedBrainrot" then checkRB(rb,rn) end end
        end
    end
    if next(state.selectedTypes)==nil or state.selectedTypes["Divine"] then
        for _, rb in pairs(ab:GetDescendants()) do
            if rb.Name=="RenderedBrainrot" and isDivine(rb) then checkRB(rb,"Divine") end
        end
    end
    return best
end

local function findLuckyBlock(targetRarity)
    local alb = workspace:FindFirstChild("ActiveLuckyBlocks") if not alb then return end
    for _, lb in pairs(alb:GetDescendants()) do
        if lb:IsA("Model") and lb.Name:find("_") then
            local parts = lb.Name:split("_")
            local r = parts[#parts]
            if targetRarity=="All" or r==targetRarity then
                return {Model=lb, Rarity=r, Position=lb:GetPivot().Position}
            end
        end
    end
end

local function getTarget()
    if state.farmTargetType=="Best Brainrot" then return findBestBrainrot(nil)
    elseif state.farmTargetType=="Brainrot" then return findBestBrainrot(state.farmTargetRarity)
    else return findLuckyBlock(state.farmTargetRarity) end
end

