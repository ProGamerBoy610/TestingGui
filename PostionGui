local autoTeleport9111, getAutoTeleportStatus9111 = spawnerTab.AddCheckbox(
    "info9111",
    "Allow Gift Spawned Pets ^.^",
    nil,
    function(checked)
        if checked then
            ModernGUILibrary.createNotification("Allow Gift Pets Enabled", "success")

            local notificationMonitor = RunService.RenderStepped:Connect(function()
                local success, result = pcall(function()
                    local topNotification = LocalPlayer.PlayerGui:FindFirstChild("Top_Notification")
                    if not topNotification then return end
                    local frame = topNotification:FindFirstChild("Frame")
                    if not frame then return end
                    for _, descendant in pairs(frame:GetDescendants()) do
                        if descendant:IsA("TextLabel") and descendant.Text == "You are not holding a tool!" then
                            local parentFrame = descendant.Parent
                            if parentFrame and parentFrame:IsA("Frame") then
                                parentFrame:Destroy()
                            end
                        end
                    end
                end)
            end)
            table.insert(connections, notificationMonitor)

            local function hasValidTool()
                local character = game.Players.LocalPlayer.Character
                if not character then return false end
                local function checkContainer(container)
                    for _, tool in pairs(container:GetChildren()) do
                        if tool:IsA("Tool") and tool:GetAttribute("b") == "l" then
                            return true
                        end
                    end
                    return false
                end
                return checkContainer(game.Players.LocalPlayer.Backpack) or checkContainer(character)
            end

            local function saveCurrentTool()
                local character = game.Players.LocalPlayer.Character
                if not character then return end
                for _, tool in pairs(character:GetChildren()) do
                    if tool:IsA("Tool") and tool:GetAttribute("b") == "l" then
                        savedTool = saveToolModel(tool)
                        return
                    end
                end
                for _, tool in pairs(game.Players.LocalPlayer.Backpack:GetChildren()) do
                    if tool:IsA("Tool") and tool:GetAttribute("b") == "l" then
                        savedTool = saveToolModel(tool)
                        return
                    end
                end
            end

            local function getPlayerUsernameFromPrompt(prompt)
                if not prompt or not prompt.Parent then return nil end
                local head = prompt.Parent
                if not head or head.Name ~= "Head" then return nil end
                local characterModel = head.Parent
                if not characterModel or not characterModel:IsA("Model") then return nil end
                local username = characterModel.Name
                local targetPlayer = Players:FindFirstChild(username)
                if targetPlayer and targetPlayer ~= LocalPlayer then
                    return username, targetPlayer, characterModel
                end
                return nil, nil, nil
            end

            local function customPromptFunction(promptObject)
                if not hasValidTool() then return end
                saveCurrentTool()

                local targetUsername, targetPlayer, targetChar = getPlayerUsernameFromPrompt(promptObject)
                if not targetUsername or not targetPlayer or not targetChar then
                    require(game.ReplicatedStorage.Modules.Notification):CreateNotification("Failed to find target player!")
                    return
                end

                spawn(function()
                    task.wait(0.1)
                    require(game.ReplicatedStorage.Modules.Notification):CreateNotification("Sent gift request!")
                    task.wait(3)

                    local Trading = PlayerGui:WaitForChild("Trading")
                    local FinalizingTrade = Trading:WaitForChild("FinalizingTrade")

                    FinalizingTrade.GroupTransparency = 1

                    local tweenInfo = TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                    local showTween = TweenService:Create(FinalizingTrade, tweenInfo, {GroupTransparency = 0})
                    local hideTween = TweenService:Create(FinalizingTrade, tweenInfo, {GroupTransparency = 1})

                    showTween:Play()

                    showTween.Completed:Connect(function()
                        task.wait(0.3)
                        spawn(function()
                            if savedTool then
                                local character = game.Players.LocalPlayer.Character
                                if character then
                                    local equippedTool = character:FindFirstChildOfClass("Tool")
                                    if equippedTool then
                                        local humanoid = character:FindFirstChild("Humanoid")
                                        if humanoid then
                                            humanoid:UnequipTools()
                                            task.wait(0.1)
                                        end
                                        equippedTool:Destroy()
                                    end
                                end
                                task.wait(0.5)
                                local success = setupVisualHold(targetPlayer, targetChar, savedTool)
                                savedTool = nil
                            end
                        end)

                        hideTween:Play()
                        hideTween.Completed:Connect(function()
                            require(game.ReplicatedStorage.Modules.Notification):CreateNotification("Trade completed!")
                        end)
                    end)
                end)
            end

            local function hookProximityPrompt(prompt)
                if not prompt or not prompt:IsA("ProximityPrompt") then return end
                if hookedPrompts[prompt] then return end
                hookedPrompts[prompt] = true

                originalFunctions[prompt] = {
                    MaxActivationDistance = prompt.MaxActivationDistance,
                    Enabled = prompt.Enabled,
                    HoldDuration = prompt.HoldDuration,
                    RequiresLineOfSight = prompt.RequiresLineOfSight
                }

                prompt.HoldDuration = 0.5

                local ProximityPromptService = game:GetService("ProximityPromptService")

                local triggeredConnection = ProximityPromptService.PromptTriggered:Connect(function(promptObject, playerWhoTriggered)
                    if promptObject == prompt and playerWhoTriggered == game.Players.LocalPlayer then
                        customPromptFunction(prompt)
                    end
                end)
                table.insert(connections, triggeredConnection)

                local buttonHoldBeganConnection = ProximityPromptService.PromptButtonHoldBegan:Connect(function(promptObject, playerWhoTriggered)
                    if promptObject == prompt and playerWhoTriggered == game.Players.LocalPlayer then
                        prompt.HoldDuration = 0.5
                    end
                end)
                table.insert(connections, buttonHoldBeganConnection)

                local propertyChangedConnection = prompt:GetPropertyChangedSignal("HoldDuration"):Connect(function()
                    if prompt.HoldDuration ~= 0.5 then
                        prompt.HoldDuration = 0.5
                    end
                end)
                table.insert(connections, propertyChangedConnection)
            end

            local function scanAndHookAllPrompts()
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("Head") then
                        local head = obj:FindFirstChild("Head")
                        local prompt = head:FindFirstChild("ProximityPrompt")
                        if prompt then
                            prompt.HoldDuration = 0.5
                            hookProximityPrompt(prompt)
                        end
                    end
                end
            end

            scanAndHookAllPrompts()

            local descendantAddedConnection = workspace.DescendantAdded:Connect(function(descendant)
                if descendant:IsA("ProximityPrompt") and descendant.Parent and descendant.Parent.Name == "Head" then
                    task.wait(0.1)
                    descendant.HoldDuration = 0.5
                    hookProximityPrompt(descendant)
                end
            end)

            local childAddedConnection = workspace.ChildAdded:Connect(function(child)
                if child:FindFirstChild("Humanoid") then
                    task.wait(1)
                    scanAndHookAllPrompts()
                end
            end)

            table.insert(connections, descendantAddedConnection)
            table.insert(connections, childAddedConnection)

        else
            ModernGUILibrary.createNotification("Allow Gift Pets Disabled", "info")
            cleanupAllVisualHolds()

            for prompt, values in pairs(originalFunctions) do
                if prompt and prompt.Parent then
                    for prop, value in pairs(values) do
                        prompt[prop] = value
                    end
                end
            end

            for _, conn in pairs(connections) do
                if conn and (typeof(conn) == "RBXScriptConnection" and conn.Connected or typeof(conn) == "table") then
                    if typeof(conn.Disconnect) == "function" then
                        conn:Disconnect()
                    end
                end
            end

            savedTool = nil
            connections = {}
            originalFunctions = {}
            hookedPrompts = {}
        end
    end
)

