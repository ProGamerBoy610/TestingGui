-- ============================================================
local function notify(msg, t) ModernGUI.createNotification(msg, t or "success") end

local function isAlive()
    return character and character.Parent
        and humanoid and humanoid.Health > 0
        and hrp and hrp.Parent
end

local function parseRate(t)
    if not t then return 0 end
    local s = t:gsub("%$",""):gsub("/s",""):gsub(" ","")
    for sfx, m in pairs({K=1e3,M=1e6,B=1e9,T=1e12}) do
        if s:upper():find(sfx) then
            local n = tonumber(s:match("([%d%.]+)")) return n and n*m or 0
        end
    end
    return tonumber(s) or 0
end

local function getTimeLeft(rb)
    local r = rb:FindFirstChild("Root")
    if r then
        local tg = r:FindFirstChild("TimerGui")
        if tg then local tl = tg:FindFirstChild("TimeLeft") if tl and tl:IsA("TextLabel") then return tl.Text end end
    end
    return "N/A"
end

local function isDivine(rb)
    for _, c in pairs(rb:GetDescendants()) do
        if c:IsA("TextLabel") and c.Name=="Class" and c.Text=="Divine" then return true end
    end
    return false
end

local function getRate(rb)
    for _ = 1, 3 do
        for _, c in pairs(rb:GetChildren()) do
            if c:IsA("Model") then
                local me = c:FindFirstChild("ModelExtents")
                if me then
                    local sg = me:FindFirstChild("StatsGui")
                    if sg then
                        local f = sg:FindFirstChild("Frame")
                        if f then local r = f:FindFirstChild("Rate") if r and r.Text~="" then return r.Text end end
                    end
                end
            end
        end
        task.wait(0.1)
    end
    for _, o in pairs(rb:GetDescendants()) do
        if o:IsA("TextLabel") and o.Text and o.Text:find("%$") then return o.Text end
    end
end

local function isHolding()
    return character and character:FindFirstChild("RenderedBrainrot") ~= nil
end

