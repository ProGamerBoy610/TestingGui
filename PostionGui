                    "@everyone\n\n🚨 **DIVINE SPAWNOU!**\n💰 **Rate:** "..(rt or "?").."\n⏰ **Time Left:** "..tl)
            end)
        end
        if state.alertESP then
            local model=nil for _,o in pairs(d:GetChildren()) do if o:IsA("Model") then model=o break end end
            if model then table.insert(espObjects, createESP(model,"[Divine]\n"..(rt or ""),RC.Divine,tl)) end
        end
        if state.showAllESP then refreshAllBrainrotESP() end
    end)
end)

