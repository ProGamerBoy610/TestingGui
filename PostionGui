-- Runtime Anti-Logger
do
    local _ENV = getfenv(0)
    local _FUNCS = {}
    _FUNCS[1] = _ENV.request
    _FUNCS[2] = _ENV.http_request
    if _ENV.syn then _FUNCS[3] = _ENV.syn.request end
    if _ENV.http then _FUNCS[4] = _ENV.http.request end

    local _BLOCKED = {
        "discord%.com/api/webhooks",
        "discordapp%.com/api/webhooks",
        "webhook%.site",
        "webhook",
        "grabify",
        "iplogger",
        "ip%-api%.com"
    }

    local _ALLOWED = {
        "pastefy%.app",
        "raw%.githubusercontent%.com",
        "pastebin%.com/raw",
        "roblox%.com",
        "rbxcdn%.com"
    }

    local function _check(url)
        url = string.lower(tostring(url))
        for i = 1, #_ALLOWED do
            if string.find(url, _ALLOWED[i]) then return true end
        end
        for i = 1, #_BLOCKED do
            if string.find(url, _BLOCKED[i]) then return false end
        end
        return true
    end

    local function _wrap(fn)
        return function(req)
            local url = req and (req.Url or req.URL) or ""
            if not _check(url) then
                warn("[BLOCKED] " .. url)
                return {Success = false, StatusCode = 403, Body = "Blocked"}
            end
            return fn(req)
        end
    end

    if _FUNCS[1] then _ENV.request = _wrap(_FUNCS[1]) end
    if _FUNCS[2] then _ENV.http_request = _wrap(_FUNCS[2]) end
    if _FUNCS[3] then _ENV.syn.request = _wrap(_FUNCS[3]) end
    if _FUNCS[4] then _ENV.http.request = _wrap(_FUNCS[4]) end

    pcall(function()
        local _HS = game:GetService("HttpService")
        if _HS.GetAsync then
            local _OLD_GET = _HS.GetAsync
            _HS.GetAsync = function(self, url, ...)
                if not _check(url) then
                    warn("[BLOCKED] GetAsync: " .. url)
                    error("Request blocked")
                end
                return _OLD_GET(self, url, ...)
            end
        end
        if _HS.PostAsync then
            local _OLD_POST = _HS.PostAsync
            _HS.PostAsync = function(self, url, ...)
                if not _check(url) then
                    warn("[BLOCKED] PostAsync: " .. url)
                    error("Request blocked")
                end
                return _OLD_POST(self, url, ...)
            end
        end
    end)

    pcall(function()
        if _ENV.decompile then
            _ENV.decompile = function() error("[BLOCKED] Decompilation") end
        end
        if _ENV.getscriptclosure then
            _ENV.getscriptclosure = function()
                warn("[BLOCKED] getscriptclosure")
                return function() error("[BLOCKED]") end
            end
        end
    end)

    warn("[PROTECTED]")
end

