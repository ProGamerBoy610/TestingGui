        hrp=character:WaitForChild("HumanoidRootPart")
        humanoid=character:WaitForChild("Humanoid")
        notify("Auto Farm V2 ativado!")
        task.spawn(function()
            while state.autoFarmV2 do
                if not state.isFarmingV2 and isAlive() then
                    doFarmV2()
                elseif not isAlive() then
                    notify("Você morreu! Esperando respawn...","warning")
                    player.CharacterAdded:Wait() task.wait(2)
                    character=player.Character
                    hrp=character:WaitForChild("HumanoidRootPart")
                    humanoid=character:WaitForChild("Humanoid")
                    notify("Respawn! Continuando farm V2...")
                end
                task.wait(3)
            end
        end)
    else
        state.autoFarmV2=false state.isFarmingV2=false
        notify("Auto Farm V2 desativado!","warning")
    end
end)

