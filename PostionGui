local function spawnPlant(plantName)
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    -- Get the plant model
    local plantModel = plantModelsFolder:FindFirstChild(plantName)
    if not plantModel then return end
    
    -- Clone the plant
    local plantClone = plantModel:Clone()
    
    -- Get player position and look direction
    local humanoidRootPart = character.HumanoidRootPart
    local playerPosition = humanoidRootPart.Position
    local lookDirection = humanoidRootPart.CFrame.LookVector
    
    -- Calculate spawn position (7 studs in front)
    local spawnPosition = playerPosition + (lookDirection * 7)
    
    -- Find the center and lowest point of the plant model
    local modelCFrame, modelSize = plantModel:GetBoundingBox()
    local modelBottomY = modelCFrame.Position.Y - (modelSize.Y / 2)
    
    -- Calculate Y offset to place plant bottom at player's feet level, then lower by 2 studs
    local playerFeetY = playerPosition.Y - (humanoidRootPart.Size.Y / 2)
    local yOffset = (playerFeetY - modelBottomY) - 2
    
    -- Calculate the offset from model center to desired spawn center
    local centerOffset = Vector3.new(
        spawnPosition.X - modelCFrame.Position.X,
        yOffset,
        spawnPosition.Z - modelCFrame.Position.Z
    )
    
    -- Move all parts by the offset
    for _, part in pairs(plantClone:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Position = part.Position + centerOffset
            part.Anchored = true
        end
    end
    
    -- Parent to workspace
    plantClone.Parent = workspace
    
    return plantClone
end

