-- SHOW ALL ESP HELPERS
-- ============================================================
local function refreshAllBrainrotESP()
    clearESPs(allESPObjects) allESPObjects={}
    if not state.showAllESP then return end
    local ab = workspace:FindFirstChild("ActiveBrainrots") if not ab then return end
    for _, rf in pairs(ab:GetChildren()) do
        local rn=rf.Name
        if state.alertRarities[rn] then
            for _, rb in pairs(rf:GetChildren()) do
                if rb.Name=="RenderedBrainrot" then
                    local model=nil for _,o in pairs(rb:GetChildren()) do if o:IsA("Model") then model=o break end end
                    if model then
                        local rt=getRate(rb)
                        table.insert(allESPObjects, createESP(model,"["..rn.."\n"..(rt or ""),RC[rn] or Color3.new(1,1,1),getTimeLeft(rb)))
                    end
                end
            end
        end
    end
    if state.alertRarities["Divine"] then
        for _, rb in pairs(ab:GetDescendants()) do
            if rb.Name=="RenderedBrainrot" and isDivine(rb) then
                local model=nil for _,o in pairs(rb:GetChildren()) do if o:IsA("Model") then model=o break end end
                if model then
                    local rt=getRate(rb)
                    table.insert(allESPObjects, createESP(model,"[Divine]\n"..(rt or ""),RC.Divine,getTimeLeft(rb)))
                end
            end
        end
    end
    notify("ESP em "..#allESPObjects.." brainrots!")
end

local function refreshAllLBESP()
    clearESPs(allLBESPObjects) allLBESPObjects={}
    if not state.showAllLBESP then return end
    local alb = workspace:FindFirstChild("ActiveLuckyBlocks") if not alb then return end
    for _, lb in pairs(alb:GetDescendants()) do
        if lb:IsA("Model") and lb.Name:find("_") then
            local parts=lb.Name:split("_") local r=parts[#parts]
            if state.alertLBRarities[r] then
                table.insert(allLBESPObjects, createESP(lb,"[LUCKY BLOCK]\n"..r, RC[r] or Color3.fromRGB(255,255,0)))
            end
        end
    end
    notify("ESP em "..#allLBESPObjects.." Lucky Blocks!")
end

