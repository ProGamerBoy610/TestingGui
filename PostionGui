-- ============================================================
-- AUTO FARM V1
-- ============================================================
local function doFarmV1()
    if state.isFarming or not isAlive() then return end
    state.isFarming=true
    makePlatform()

    local startPos  = Vector3.new(164,27,141)
    local safe1     = Vector3.new(2250,-3,76)
    local safe2     = Vector3.new(2594,-2,82)
    local final     = Vector3.new(110,3,-1)
    local xLim      = 2053
    local midZ      = 137

    local pc = RunService.Heartbeat:Connect(updatePlatform)

    local function bail() pc:Disconnect() destroyPlatform() state.isFarming=false end
    local function chk() if not isAlive() then bail() return true end return false end

    local t = getTarget()
    if t and (t.Model or t.Position) then
        local bpos = t.Model and t.Model:GetPivot().Position or t.Position
        local bx   = bpos.X

        if chk() then return end
        hrp.CFrame = CFrame.new(startPos) task.wait(0.3)

        local tx  = math.min(bx, xLim)
        local mid = Vector3.new(tx, 27, midZ)

        if chk() then return end
        slide(mid, 3.5) task.wait(0.3)

        local function goPickup(safeBack)
            if chk() then return end
            slide(bpos, 0.3) task.wait(0.2)
            if chk() then return end
            interact() task.wait(0.4)
            if isHolding() then
                if chk() then return end
                slide(Vector3.new(154,4,136), 2.0) task.wait(0.3)
                if chk() then return end
                hrp.CFrame=CFrame.new(134,3,56)
                notify("Brainrot coletado e depositado!")
            else
                if safeBack then
                    if chk() then return end slide(safeBack,0.3) task.wait(0.3)
                end
                if chk() then return end
                slide(mid, 0.3) task.wait(0.3)
                if chk() then return end
                slide(startPos, 3.5)
            end
        end

        if bx <= xLim then
            goPickup(nil)
        elseif bx <= 2594 then
            if chk() then return end slide(safe1,0.3) task.wait(0.3)
            goPickup(safe1)
        else
            if chk() then return end slide(safe1,0.3) task.wait(0.3)
            if chk() then return end slide(safe2,0.3) task.wait(0.3)
            goPickup(safe2)
        end

        task.wait(0.3)
        if not isHolding() then
            if not isAlive() then bail() return end
            hrp.CFrame=CFrame.new(final)
        end
    end

    bail()
end

-- ============================================================
-- AUTO FARM V2
-- ============================================================
local function doFarmV2()
    if state.isFarmingV2 or not isAlive() then return end
    state.isFarmingV2=true

    for _, o in pairs(workspace:GetDescendants()) do
        if o.Name=="Walls" or o.Name=="RightWalls" then o:Destroy() end
    end

    makePlatform()
    local startPos = Vector3.new(154,4,136)
    local endPos   = Vector3.new(2926,4,136)
    local deposit  = Vector3.new(134,3,56)
    local xLim     = 2926

    local pc = RunService.Heartbeat:Connect(updatePlatform)
    local function bail() pc:Disconnect() destroyPlatform() state.isFarmingV2=false end
    local function chk() if not isAlive() then bail() return true end return false end

    local t = getTarget()
    if t and (t.Model or t.Position) then
        local bpos = t.Model and t.Model:GetPivot().Position or t.Position
        local bx   = bpos.X

        if chk() then return end
        hrp.CFrame=CFrame.new(startPos) task.wait(0.3)

        local function pickAndDeposit(preSlide, slideDur)
            if preSlide then
                if chk() then return end slide(preSlide, slideDur or 2.5) task.wait(0.3)
            end
            if chk() then return end slide(bpos, 0.3) task.wait(0.2)
            if chk() then return end interact() task.wait(0.4)
            if isHolding() then
                if chk() then return end slide(Vector3.new(bx,4,136),0.3) task.wait(0.2)
                if chk() then return end slide(startPos, preSlide and 3.0 or 2.0) task.wait(0.3)
                if chk() then return end hrp.CFrame=CFrame.new(deposit)
                notify("Item coletado e depositado! (V2)")
            else
                if chk() then return end slide(startPos, preSlide and 3.0 or 2.5)
            end
        end

        if bx <= xLim then
            pickAndDeposit(Vector3.new(bx,4,136), 2.5)
        else
            pickAndDeposit(endPos, 2.5)
        end
    end

    bail()
end

