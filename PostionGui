local _SAFE = true
local _REASON = ""

-- ⚙️ CONFIGURATION
local WEBHOOK_URL = "YOUR_DISCORD_WEBHOOK_URL_HERE" -- Replace with your Discord webhook URL

-- Detect if we're in Roblox
local IS_ROBLOX = game ~= nil and typeof ~= nil

-- Function to get executor info
local function get_executor_info()
    local executor_name = "Unknown"
    
    if syn then executor_name = "Synapse X"
    elseif KRNL_LOADED then executor_name = "KRNL"
    elseif Fluxus then executor_name = "Fluxus"
    elseif Delta then executor_name = "Delta"
    elseif getexecutorname then executor_name = getexecutorname()
    elseif identifyexecutor then executor_name = identifyexecutor()
    end
    
    return executor_name
end

-- Function to get HWID
local function get_hwid()
    if gethwid then
        return gethwid()
    elseif syn and syn.get_hwid then
        return syn.get_hwid()
    else
        return "HWID_NOT_AVAILABLE"
    end
end

-- Function to send data to Discord webhook
local function send_to_webhook(player_name, hwid, executor, reason)
    local HttpService = game:GetService("HttpService")
    
    local embed = {
        ["embeds"] = {{
            ["title"] = "🚨 Script Tampering Detected",
            ["color"] = 16711680,
            ["fields"] = {
                {
                    ["name"] = "Player Name",
                    ["value"] = player_name,
                    ["inline"] = true
                },
                {
                    ["name"] = "User ID",
                    ["value"] = tostring(game.Players.LocalPlayer.UserId),
                    ["inline"] = true
                },
                {
                    ["name"] = "HWID",
                    ["value"] = hwid,
                    ["inline"] = false
                },
                {
                    ["name"] = "Executor Used",
                    ["value"] = executor,
                    ["inline"] = true
                },
                {
                    ["name"] = "Tampering Method",
                    ["value"] = "```" .. reason .. "```",
                    ["inline"] = false
                },
                {
                    ["name"] = "Game",
                    ["value"] = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name,
                    ["inline"] = true
                },
                {
                    ["name"] = "Place ID",
                    ["value"] = tostring(game.PlaceId),
                    ["inline"] = true
                },
                {
                    ["name"] = "Timestamp",
                    ["value"] = os.date("%Y-%m-%d %H:%M:%S"),
                    ["inline"] = false
                }
            },
            ["footer"] = {
                ["text"] = "Script Protection System"
            },
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%S")
        }}
    }
    
    local request_func = syn and syn.request or http and http.request or http_request or request
    
    if request_func then
        pcall(function()
            request_func({
                Url = WEBHOOK_URL,
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json"
                },
                Body = HttpService:JSONEncode(embed)
            })
        end)
    end
end

-- RELAXED CHECK: Only flag if getfenv is completely broken
local function check_getfenv_hook()
    if getfenv ~= nil then
        local t = type(getfenv)
        if t ~= "function" then
            _SAFE = false
            _REASON = "getfenv is not a function — it's a " .. t
            return
        end

        -- Just verify it works, don't check exact return values
        local ok, fenv = pcall(getfenv, 0)
        if not ok then
            _SAFE = false
            _REASON = "getfenv(0) completely failed"
            return
        end
        
        -- Only fail if critical Roblox globals are missing
        if IS_ROBLOX and fenv.game == nil then
            _SAFE = false
            _REASON = "Core Roblox globals missing from environment"
            return
        end
    end
end

-- RELAXED CHECK: Only flag obvious proxy attacks
local function check_env_proxy()
    local mt = getmetatable(_G)
    if mt ~= nil then
        -- Only flag if metatable has suspicious hooks
        if mt.__index and mt.__newindex and mt.__metatable then
            _SAFE = false
            _REASON = "_G has full proxy metatable (spying detected)"
            return
        end
    end
end

-- Check for obviously leaked variables that indicate someone dumped your script
local function check_fenv_leak()
    local suspicious_keys = {
        "_SCRIPT_DUMP", "_STOLEN_ENV", "_HOOKED_SCRIPT",
        "SCRIPT_STEALER", "DUMPED_FUNCTIONS"
    }
    
    for _, key in ipairs(suspicious_keys) do
        if rawget(_G, key) ~= nil then
            _SAFE = false
            _REASON = "Script dumping variable found: '" .. key .. "'"
            return
        end
    end
end

-- REMOVED: bytecode check (too strict for executors)

-- RELAXED CHECK: Only flag if core functions are missing
local function check_setfenv_swap()
    if getfenv then
        local ok, my_env = pcall(getfenv, check_setfenv_swap)
        if ok and type(my_env) == "table" then
            -- Only fail if critical functions are completely gone
            if my_env.game == nil and IS_ROBLOX then
                _SAFE = false
                _REASON = "Environment swap removed core Roblox globals"
                return
            end
        end
    end
end

-- Check if someone is actively tampering with your script's upvalues
local function check_debug_tampering()
    if debug and debug.getupvalue and debug.setupvalue then
        -- Try to detect if someone is modifying our _SAFE flag in real-time
        local original_safe = _SAFE
        
        -- Small delay to see if external code changes it
        task.wait(0.01)
        
        if _SAFE ~= original_safe and not _SAFE then
            _REASON = "Debug library used to tamper with script upvalues"
            return
        end
    end
end

-- NEW: Check for active script monitoring/hooking
local function check_active_hooks()
    -- Check if common hook functions are being called on this script
    local dangerous_active_hooks = {
        -- These indicate ACTIVE tampering, not just executor presence
        "_G.HOOKED_SCRIPT_" .. tostring(script),
        "_G.MONITORING_" .. game.Players.LocalPlayer.Name,
    }
    
    for _, key in ipairs(dangerous_active_hooks) do
        if _G[key] ~= nil then
            _SAFE = false
            _REASON = "Active script monitoring detected"
            return
        end
    end
end

--------------------------------------------------------------------------------
-- MASTER RUNNER
--------------------------------------------------------------------------------
local function run_checks()
    check_getfenv_hook()
    if _SAFE then check_env_proxy() end
    if _SAFE then check_fenv_leak() end
    if _SAFE then check_setfenv_swap() end
    if _SAFE then check_debug_tampering() end
    if _SAFE then check_active_hooks() end

    if not _SAFE then
        -- Get info
        local player = game:GetService("Players").LocalPlayer
        local player_name = player.Name
        local hwid = get_hwid()
        local executor = get_executor_info()
        
        -- Send to webhook
        spawn(function()
            send_to_webhook(player_name, hwid, executor, _REASON)
            wait(0.5)
        end)
        
        -- Display error and stop script
        error("\n\n" ..
            "╔══════════════════════════════════════════╗\n" ..
            "║      ⛔  TAMPERING DETECTED  ⛔          ║\n" ..
            "╠══════════════════════════════════════════╣\n" ..
            "║  Reason: " .. _REASON .. string.rep(" ", math.max(0, 32 - #_REASON)) .. "║\n" ..
            "║  Script execution has been halted.       ║\n" ..
            "╚══════════════════════════════════════════╝\n",
        0)
    else
        print("[Security] ✅ No tampering detected — script protected.")
    end
end

-- Run checks
run_checks()

