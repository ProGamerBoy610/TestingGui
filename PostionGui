TabCombat.AddCheckbox("WallCheckESP", "Player ESP Wall Check", nil, function(checked)
    espWallCheckEnabled = checked
    if checked then
        local colorVisible = Color3.fromRGB(0, 255, 0)
        local colorHidden  = Color3.fromRGB(255, 0, 0)

        local rayParams2 = RaycastParams.new()
        rayParams2.FilterType  = Enum.RaycastFilterType.Exclude
        rayParams2.IgnoreWater = true

        local function isVisible(targetCharacter)
            local char = LocalPlayer.Character
            if not char then return false end
            local head      = char:FindFirstChild("Head")
            local targetHRP = targetCharacter:FindFirstChild("HumanoidRootPart")
            if not head or not targetHRP then return false end
            local direction = (targetHRP.Position - head.Position).Unit
            local distance  = (targetHRP.Position - head.Position).Magnitude
            rayParams2.FilterDescendantsInstances = {char, targetCharacter}
            return workspace:Raycast(head.Position, direction * distance, rayParams2) == nil
        end

        local function createWallHL(character)
            if character:FindFirstChild("ESPHighlight") then return end
            local hl = Instance.new("Highlight")
            hl.Name               = "ESPHighlight"
            hl.FillTransparency   = 0.5
            hl.OutlineTransparency = 0
            hl.OutlineColor       = colorHidden
            hl.FillColor          = colorHidden
            hl.Adornee            = character
            hl.Parent             = character
        end

        local function removeWallHL(character)
            local hl = character:FindFirstChild("ESPHighlight")
            if hl then hl:Destroy() end
        end

        local function updateWallHL(targetPl)
            if not targetPl.Character then return end
            local hl = targetPl.Character:FindFirstChild("ESPHighlight")
            if not hl then return end
            local vis  = isVisible(targetPl.Character)
            local col  = vis and colorVisible or colorHidden
            hl.FillColor    = col
            hl.OutlineColor = col
        end

        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                if p.Character then createWallHL(p.Character) updateWallHL(p) end
                local c = p.CharacterAdded:Connect(function(char) wait(0.5) createWallHL(char) updateWallHL(p) end)
                table.insert(espConnections, c)
            end
        end

        local pa = Players.PlayerAdded:Connect(function(p)
            local c = p.CharacterAdded:Connect(function(char) wait(0.5) if p ~= LocalPlayer then createWallHL(char) updateWallHL(p) end end)
            table.insert(espConnections, c)
        end)
        table.insert(espConnections, pa)

        local hb = RunService.Heartbeat:Connect(function()
            for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then updateWallHL(p) end end
        end)
        table.insert(espConnections, hb)

        local pr = Players.PlayerRemoving:Connect(function(p)
            if p.Character then removeWallHL(p.Character) end
        end)
        table.insert(espConnections, pr)

        ModernGUI.createNotification("Wall Check ESP Enabled", "success")
    else
        for _, conn in pairs(espConnections) do conn:Disconnect() end
        espConnections = {}
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character then
                local hl = p.Character:FindFirstChild("ESPHighlight")
                if hl then hl:Destroy() end
            end
        end
        ModernGUI.createNotification("Wall Check ESP Disabled", "warning")
    end
end)

