local function clearAllTargetTraderItems()
    local player = game:GetService("Players").LocalPlayer
    local tradingUI = player.PlayerGui:FindFirstChild("TradingUI")
    
    if tradingUI then
        local targetLocation = tradingUI.Main.Main.Holder.Main.TargetTrader.Main.Items.Main
        if targetLocation then
            -- Hapus SEMUA ItemTemplate
            for _, child in pairs(targetLocation:GetChildren()) do
                if child.Name == "ItemTemplate" then
                    child:Destroy()
                end
            end
        end
    end
end

-- Function untuk spawn pet
local function spawnPetInTrade()
    local player = game:GetService("Players").LocalPlayer
    
    local tradingUI = player.PlayerGui:FindFirstChild("TradingUI")
    if not tradingUI then
        ModernGUILibrary.createNotification("Trading UI not found!", "error")
        return false
    end
    
    -- Check apakah TradingUI enabled
    if not tradingUI.Enabled then
        ModernGUILibrary.createNotification("Sorry, But you're not in trade", "error")
        return false
    end
    
    local sourcePath = tradingUI.Main.Main.Holder.Main.LocalTrader.Main.Items.Main:FindFirstChild("ItemTemplate")
    if not sourcePath then
        ModernGUILibrary.createNotification("Source not found!", "error")
        return false
    end
    
    local targetLocation = tradingUI.Main.Main.Holder.Main.TargetTrader.Main.Items.Main
    if not targetLocation then
        ModernGUILibrary.createNotification("Target not found!", "error")
        return false
    end
    
    local clonedTemplate = sourcePath:Clone()
    clonedTemplate.Name = "ItemTemplate"
    clonedTemplate.Parent = targetLocation
    
    local itemImage = clonedTemplate:FindFirstChild("ITEM_IMAGE")
    if itemImage and petIcons[selectedPet] then
        itemImage.Image = petIcons[selectedPet]
    end
    
    local uiStroke = clonedTemplate:FindFirstChild("UIStroke")
    if uiStroke and colorValues[selectedColor] then
        uiStroke.Color = colorValues[selectedColor]
    end
    
    local hoverOverlay = clonedTemplate:FindFirstChild("Hover_Overlay")
    if hoverOverlay then
        local itemName = hoverOverlay:FindFirstChild("ITEM_NAME")
        if itemName then
            itemName.Text = selectedPet
        end
        
        local itemWeight = hoverOverlay:FindFirstChild("ITEM_WEIGHT")
        if itemWeight then
            itemWeight.Text = lastInputWeight .. "kg"
        end
    end
    
    clonedTemplate.Visible = true
    
    ModernGUILibrary.createNotification("Pet spawned in trade: " .. selectedPet .. " (" .. selectedColor .. " - " .. lastInputWeight .. "kg)", "success")
    return true
end

-- Function untuk memulai monitoring permanen (tidak bisa dimatikan)
local function startPermanentTradingMonitor()
    if tradingMonitorActive then
        return -- Sudah aktif, tidak perlu start lagi
    end
    
    tradingMonitorActive = true
    local player = game:GetService("Players").LocalPlayer
    local RunService = game:GetService("RunService")
    
    spawn(function()
        local lastTradingState = nil
        
        while tradingMonitorActive do
            local tradingUI = player.PlayerGui:FindFirstChild("TradingUI")
            
            if tradingUI then
                local currentState = tradingUI.Enabled
                
                -- Jika status berubah dari enabled ke disabled
                if lastTradingState == true and currentState == false then
                    clearAllTargetTraderItems()
                    
                end
                
                lastTradingState = currentState
            end
            
            wait(0.1) -- Check setiap 0.1 detik
        end
    end)
    
    ModernGUILibrary.createNotification("Pet Spawned", "success")
end

