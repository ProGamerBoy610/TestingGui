-- ============================================================
local activeBrainrots = workspace:WaitForChild("ActiveBrainrots")

for _, rf in pairs(activeBrainrots:GetChildren()) do
    rf.ChildAdded:Connect(function(child)
        if child.Name~="RenderedBrainrot" then return end
        local rn=rf.Name
        if state.alertRarities[rn] then
            task.spawn(function()
                local rt=getRate(child) local tl=getTimeLeft(child)
                notify("["..rn.."] Spawnou! "..(rt or "").."\nTime: "..tl)
                if state.alertWebhook~="" then
                    task.spawn(function()
                        sendWebhook(state.alertWebhook,
                            "@everyone\n\n🚨 **BRAINROT SPAWNOU!**\n⭐ **Raridade:** "..rn..
                            "\n💰 **Rate:** "..(rt or "?").."\n⏰ **Time Left:** "..tl)
                    end)
                end
                if state.alertESP then
                    local model=nil for _,o in pairs(child:GetChildren()) do if o:IsA("Model") then model=o break end end
                    if model then table.insert(espObjects, createESP(model,"["..rn.."]\n"..(rt or ""),RC[rn] or Color3.new(1,1,1),tl)) end
                end
                if state.showAllESP then refreshAllBrainrotESP() end
            end)
        end
        if state.bestESPEnabled then task.spawn(function() task.wait(0.3) updateBestESP() end) end
    end)
end

activeBrainrots.DescendantAdded:Connect(function(d)
    if d.Name~="RenderedBrainrot" or not isDivine(d) then return end
    if not state.alertRarities["Divine"] then return end
    task.spawn(function()
        local rt=getRate(d) local tl=getTimeLeft(d)
        notify("[Divine] Spawnou! "..(rt or "").."\nTime: "..tl)
        if state.alertWebhook~="" then
            task.spawn(function()
