    local path = player:WaitForChild("PlayerGui")
        :WaitForChild("ScreenGui")
        :WaitForChild("FrameIndex")
        :WaitForChild("Main")
        :WaitForChild("ScrollingFrame")
    for _, v in ipairs(path:GetChildren()) do
        if v:IsA("ImageButton") then
            table.insert(buttons, v)
        end
