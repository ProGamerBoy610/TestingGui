local function findBase()
    local bases = workspace:FindFirstChild("Bases") if not bases then return end
    for _, bm in pairs(bases:GetChildren()) do
        if bm:IsA("Model") then
            local title=bm:FindFirstChild("Title")
            if title then
                local tg=title:FindFirstChild("TitleGui")
                if tg then
                    local fr=tg:FindFirstChild("Frame")
                    if fr then local pn=fr:FindFirstChild("PlayerName") if pn and pn.Text==player.Name then return bm.Name end end
                end
            end
        end
    end
end

