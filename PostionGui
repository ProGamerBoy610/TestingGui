-- Advanced Anti-Tamper System for Roblox
-- Features: Multi-layer detection, graceful handling, logging, and environment integrity checks

local AntiTamper = {}
AntiTamper.TamperDetected = false
AntiTamper.TamperLog = {}
AntiTamper.Config = {
    LogDetections = true,
    StrictMode = false, -- Set to true to error on detection, false to log and continue
    CheckMetatables = true,
    CheckMath = true,
    CheckGlobals = true,
    CheckFunctions = true,
    CheckEnvironment = true,
    VerboseLogging = true,
}

-- Utility function for safe logging
local function SafeLog(message, tamperLevel)
    tamperLevel = tamperLevel or "WARNING"
    local logEntry = {
        timestamp = os.time(),
        level = tamperLevel,
        message = message,
    }
    table.insert(AntiTamper.TamperLog, logEntry)
    
    if AntiTamper.Config.LogDetections then
        print(string.format("[AntiTamper-%s] %s", tamperLevel, message))
    end
end

-- Store original values for comparison
local OriginalValues = {
    StringMetatable = getmetatable(""),
    NumberType = type(1),
    TableType = type({}),
    FunctionType = type(function() end),
    BoolType = type(true),
    NilType = type(nil),
}

-- Check 1: Verify string metatable integrity
function AntiTamper:CheckStringMetatable()
    if not self.Config.CheckMetatables then return true end
    
    local currentMeta = getmetatable("")
    
    -- In Roblox, strings might have a metatable, but check if it's been tampered with
    -- Look for suspicious __index, __newindex, or __call metamethods
    if currentMeta ~= nil then
        local hasSuspiciousMetamethods = false
        
        if currentMeta.__index ~= nil then
            hasSuspiciousMetamethods = true
        end
        if currentMeta.__newindex ~= nil then
            hasSuspiciousMetamethods = true
        end
        if currentMeta.__call ~= nil then
            hasSuspiciousMetamethods = true
        end
        
        if hasSuspiciousMetamethods then
            SafeLog("String metatable has been modified with suspicious metamethods", "CRITICAL")
            self.TamperDetected = true
            return false
        end
    end
    
    return true
end

-- Check 2: Verify table metatable integrity
function AntiTamper:CheckTableMetatable()
    if not self.Config.CheckMetatables then return true end
    
    local testTable = {}
    
    -- Test if we can safely set metatables
    local success, result = pcall(function()
        local meta = getmetatable(testTable)
        return meta
    end)
    
    if not success then
        SafeLog("Table metatable operations are compromised", "CRITICAL")
        self.TamperDetected = true
        return false
    end
    
    return true
end

-- Check 3: Verify basic arithmetic operations
function AntiTamper:CheckMathOperations()
    if not self.Config.CheckMath then return true end
    
    local mathTests = {
        {name = "Addition", fn = function() return 5 + 3 end, expected = 8},
        {name = "Subtraction", fn = function() return 10 - 3 end, expected = 7},
        {name = "Multiplication", fn = function() return 4 * 5 end, expected = 20},
        {name = "Division", fn = function() return 20 / 4 end, expected = 5},
        {name = "Modulo", fn = function() return 10 % 3 end, expected = 1},
        {name = "Power", fn = function() return 2 ^ 3 end, expected = 8},
    }
    
    for _, test in ipairs(mathTests) do
        local success, result = pcall(test.fn)
        
        if not success then
            SafeLog(string.format("Math operation %s failed: %s", test.name, tostring(result)), "CRITICAL")
            self.TamperDetected = true
            return false
        elseif result ~= test.expected then
            SafeLog(string.format("Math operation %s returned unexpected value: %s (expected %s)", test.name, tostring(result), tostring(test.expected)), "CRITICAL")
            self.TamperDetected = true
            return false
        end
    end
    
    -- Test string concatenation (commonly tampered)
    local success, result = pcall(function()
        return "Hello" .. " " .. "World"
    end)
    
    if not success or result ~= "Hello World" then
        SafeLog("String concatenation has been tampered with", "CRITICAL")
        self.TamperDetected = true
        return false
    end
    
    return true
end

-- Check 4: Verify global function integrity
function AntiTamper:CheckGlobalFunctions()
    if not self.Config.CheckFunctions then return true end
    
    local criticalGlobals = {
        "print", "error", "warn", "pcall", "xpcall", "type", "tostring", "tonumber",
        "getmetatable", "setmetatable", "rawget", "rawset", "rawequal", "next",
        "ipairs", "pairs", "table", "string", "math", "coroutine",
    }
    
    local missingCount = 0
    
    for _, globalName in ipairs(criticalGlobals) do
        local globalFunc = _G[globalName]
        
        if globalFunc == nil then
            missingCount = missingCount + 1
        elseif type(globalFunc) ~= "function" and type(globalFunc) ~= "table" then
            SafeLog(string.format("Critical global '%s' has been replaced with type '%s'", globalName, type(globalFunc)), "CRITICAL")
            self.TamperDetected = true
        end
    end
    
    -- Only flag as tampering if MORE THAN HALF of critical globals are missing
    -- This prevents false positives in sandboxed environments
    if missingCount > (#criticalGlobals / 2) then
        SafeLog(string.format("Too many critical globals missing (%d/%d)", missingCount, #criticalGlobals), "CRITICAL")
        self.TamperDetected = true
        return false
    end
    
    return true
end

-- Check 5: Verify type system integrity
function AntiTamper:CheckTypeSystem()
    if not self.Config.CheckEnvironment then return true end
    
    local typeTests = {
        {value = "", expected = "string"},
        {value = 1, expected = "number"},
        {value = {}, expected = "table"},
        {value = function() end, expected = "function"},
        {value = true, expected = "boolean"},
        {value = nil, expected = "nil"},
    }
    
    for _, test in ipairs(typeTests) do
        local actualType = type(test.value)
        if actualType ~= test.expected then
            SafeLog(string.format("Type system corrupted: %s has type '%s' (expected '%s')", tostring(test.value), actualType, test.expected), "CRITICAL")
            self.TamperDetected = true
            return false
        end
    end
    
    return true
end

-- Check 6: Verify script environment
function AntiTamper:CheckEnvironment()
    if not self.Config.CheckEnvironment then return true end
    
    local success, env = pcall(function()
        return getfenv(1)
    end)
    
    if not success then
        SafeLog("Cannot access script environment", "WARNING")
        return true -- Don't flag as critical, some environments restrict this
    end
    
    if env == nil then
        SafeLog("Script environment is nil - execution context may be compromised", "CRITICAL")
        self.TamperDetected = true
        return false
    end
    
    return true
end

-- Check 7: Verify basic table operations
function AntiTamper:CheckTableOperations()
    if not self.Config.CheckMath then return true end
    
    local testTable = {a = 1, b = 2, c = 3}
    
    -- Test table creation
    local success, result = pcall(function()
        return {x = 10, y = 20}
    end)
    
    if not success then
        SafeLog("Table creation has been compromised", "CRITICAL")
        self.TamperDetected = true
        return false
    end
    
    -- Test table indexing
    success, result = pcall(function()
        return testTable.a
    end)
    
    if not success or result ~= 1 then
        SafeLog("Table indexing has been compromised", "CRITICAL")
        self.TamperDetected = true
        return false
    end
    
    return true
end

-- Main anti-tamper check function
function AntiTamper:Run()
    SafeLog("Starting anti-tamper checks...", "INFO")
    
    local checksRun = 0
    local checksPassed = 0
    
    local checks = {
        {name = "String Metatable", fn = function() return self:CheckStringMetatable() end},
        {name = "Table Metatable", fn = function() return self:CheckTableMetatable() end},
        {name = "Math Operations", fn = function() return self:CheckMathOperations() end},
        {name = "Type System", fn = function() return self:CheckTypeSystem() end},
        {name = "Table Operations", fn = function() return self:CheckTableOperations() end},
        {name = "Global Functions", fn = function() return self:CheckGlobalFunctions() end},
        {name = "Environment", fn = function() return self:CheckEnvironment() end},
    }
    
    for _, check in ipairs(checks) do
        checksRun = checksRun + 1
        local passed = check.fn()
        if passed then
            checksPassed = checksPassed + 1
            if self.Config.VerboseLogging then
                SafeLog(string.format("✓ Check passed: %s", check.name), "OK")
            end
        else
            if self.Config.VerboseLogging then
                SafeLog(string.format("✗ Check failed: %s", check.name), "FAIL")
            end
        end
    end
    
    SafeLog(string.format("Anti-tamper checks complete: %d/%d passed", checksPassed, checksRun), "INFO")
    
    if self.TamperDetected then
        SafeLog("⚠ Tampering detected in script environment", "ALERT")
        -- Script execution will be halted in the main execution block
    end
end

-- Get tamper report
function AntiTamper:GetReport()
    return {
        TamperDetected = self.TamperDetected,
        LogCount = #self.TamperLog,
        Logs = self.TamperLog,
        Config = self.Config,
    }
end

-- Print tamper report
function AntiTamper:PrintReport()
    print("\n" .. string.rep("=", 50))
    print("ANTI-TAMPER REPORT")
    print(string.rep("=", 50))
    print("Tamper Detected: " .. tostring(self.TamperDetected))
    print("Total Log Entries: " .. #self.TamperLog)
    print(string.rep("-", 50))
    
    if #self.TamperLog > 0 then
        for i, log in ipairs(self.TamperLog) do
            print(string.format("[%d] [%s] %s", i, log.level, log.message))
        end
    else
        print("No issues detected")
    end
    
    print(string.rep("=", 50) .. "\n")
end

