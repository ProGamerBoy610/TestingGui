function addFishESP(fish)
    if not fish:FindFirstChild("Head") then return end
    if not fish.Head:FindFirstChild("stats") then return end
    if fishESP[fish] then return end

    local espData = {}

    if ESPState.FishHighlight then
        espData.Highlight = createFishHighlight(fish)
    end
    if ESPState.FishName then
        espData.NameBillboard = createFishNameBillboard(fish)
    end
    if ESPState.FishMutation then
        espData.MutationBillboard = createFishMutationBillboard(fish)
    end

    fishESP[fish] = espData
end

function addChestESP(chest, tier)
    if chestESP[chest] then return end

    local espData = {}

    if ESPState.ChestHighlight then
        espData.Highlight = createChestHighlight(chest, tier)
    end
    if ESPState.ChestName then
        espData.Billboard = createChestBillboard(chest, tier)
    end

    chestESP[chest] = espData
end

function removeFishESP(fish)
    local esp = fishESP[fish]
    if esp then
        if esp.Highlight        then esp.Highlight:Destroy()        end
        if esp.NameBillboard    then esp.NameBillboard:Destroy()    end
        if esp.MutationBillboard then esp.MutationBillboard:Destroy() end
        fishESP[fish] = nil
    end
end

function removeChestESP(chest)
    local esp = chestESP[chest]
    if esp then
        if esp.Highlight  then esp.Highlight:Destroy()  end
        if esp.Billboard  then esp.Billboard:Destroy()  end
        chestESP[chest] = nil
    end
end

function updateAllESP()
    for _, esp in pairs(fishESP) do
        if esp.Highlight         then esp.Highlight:Destroy()         end
        if esp.NameBillboard     then esp.NameBillboard:Destroy()     end
        if esp.MutationBillboard then esp.MutationBillboard:Destroy() end
    end
    fishESP = {}

    for _, esp in pairs(chestESP) do
        if esp.Highlight then esp.Highlight:Destroy() end
        if esp.Billboard then esp.Billboard:Destroy() end
    end
    chestESP = {}

    local fishFolderPath = workspace:FindFirstChild("Game")
        and workspace.Game:FindFirstChild("Fish")
        and workspace.Game.Fish:FindFirstChild("client")

    if fishFolderPath then
        for _, fish in pairs(fishFolderPath:GetChildren()) do
            addFishESP(fish)
        end
    end

    local chestsFolder = workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Chests")
    if chestsFolder then
        for _, tier in pairs({"Tier 1", "Tier 2", "Tier 3"}) do
            local tierFolder = chestsFolder:FindFirstChild(tier)
            if tierFolder then
                for _, chest in pairs(tierFolder:GetChildren()) do
                    addChestESP(chest, tier)
                end
            end
        end
    end
end

local function watchFish()
    local fishFolderPath = workspace:FindFirstChild("Game")
        and workspace.Game:FindFirstChild("Fish")
        and workspace.Game.Fish:FindFirstChild("client")

    if not fishFolderPath then
        workspace.Game.Fish:WaitForChild("client")
        fishFolderPath = workspace.Game.Fish.client
    end

    fishFolderPath.ChildAdded:Connect(function(fish)
        task.wait(0.1)
        addFishESP(fish)
    end)
    fishFolderPath.ChildRemoved:Connect(function(fish)
        removeFishESP(fish)
    end)
end

local function watchChests()
    local chestsFolder = workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Chests")
    if not chestsFolder then return end

    for _, tier in pairs({"Tier 1", "Tier 2", "Tier 3"}) do
        local tierFolder = chestsFolder:FindFirstChild(tier)
        if tierFolder then
            local tierCopy = tier
            tierFolder.ChildAdded:Connect(function(chest)
                task.wait(0.1)
                addChestESP(chest, tierCopy)
            end)
            tierFolder.ChildRemoved:Connect(function(chest)
                removeChestESP(chest)
            end)
        end
    end
end

task.spawn(function()
    watchFish()
    watchChests()
    updateAllESP()
end)

-- ---- Name/Mutation/Rarity Drawing ESP ----
getgenv().ESPSettings.Tracers     = true
getgenv().ESPSettings.MaxDistance = 100

local rarityColors = {
    Common    = Color3.fromRGB(200, 200, 200),
    Uncommon  = Color3.fromRGB(85, 255, 85),
    Rare      = Color3.fromRGB(85, 170, 255),
    Epic      = Color3.fromRGB(170, 85, 255),
    Legendary = Color3.fromRGB(255, 170, 0),
    Mythic    = Color3.fromRGB(255, 60, 60),
}

local rarityCache   = {}
local mutationCache = {}
local espDrawCache  = {}
local textCache     = {}
local connections   = {}

local fishFolderDraw = workspace:WaitForChild("Game"):WaitForChild("Fish"):WaitForChild("client")
local fishModules    = ReplicatedStorage:WaitForChild("common")
                         :WaitForChild("presets")
                         :WaitForChild("items")
                         :WaitForChild("fish")

local fishLookup = {}
for _, biome in ipairs(fishModules:GetChildren()) do
    for _, mod in ipairs(biome:GetChildren()) do
        fishLookup[mod.Name] = mod
    end
end

local mutationModules = ReplicatedStorage:WaitForChild("common")
                          :WaitForChild("presets")
                          :WaitForChild("fish")
                          :WaitForChild("mutations")

local function getMutationData(name)
    if mutationCache[name] then return mutationCache[name] end
    local mod = mutationModules:FindFirstChild(name)
    if mod then
        local ok, data = pcall(require, mod)
        if ok and data then
            mutationCache[name] = {
                color           = data.color or Color3.new(1, 1, 1),
                priceMultiplier = data.price_multiplier or 1,
            }
            return mutationCache[name]
        end
    end
    mutationCache[name] = { color = Color3.new(1, 1, 1), priceMultiplier = 1 }
    return mutationCache[name]
end

local function getRarityColor(name)
    if rarityCache[name] then return rarityCache[name] end
    local mod = fishLookup[name]
    if mod then
        local ok, data = pcall(require, mod)
        if ok and data and data.rarity then
            rarityCache[name] = rarityColors[data.rarity] or Color3.new(1, 1, 1)
            return rarityCache[name]
        end
    end
    rarityCache[name] = Color3.new(1, 1, 1)
    return rarityCache[name]
end

local function createDrawText(color)
    local t = Drawing.new("Text")
    t.Center  = true
    t.Outline = true
    t.Size    = 14
    t.Font    = 2
    t.Color   = color
    t.Visible = false
    return t
end

local function createDrawLine(color)
    local l = Drawing.new("Line")
    l.Thickness = 1.5
    l.Color     = color
    l.Visible   = false
    return l
end

local function rebuildDrawText(fish)
    local data = textCache[fish]
    if not data then return end
    data.nameColor = getRarityColor(data.name)
end

local function hookFishDraw(fish)
    local head  = fish:FindFirstChild("Head")
    local stats = (head and head:FindFirstChild("stats"))
        or (fish:FindFirstChild("RootPart") and fish.RootPart:FindFirstChild("stats"))
    if not stats then return end

    local nameLabel     = stats:FindFirstChild("Fish")
    local mutationLabel
    local mut           = stats:FindFirstChild("Mutation")
    if mut then mutationLabel = mut:FindFirstChild("Label") end

    textCache[fish] = {
        name      = nameLabel and nameLabel.Text or "",
        mutation  = mutationLabel and mutationLabel.Text or "",
        nameColor = Color3.new(1, 1, 1),
    }
    rebuildDrawText(fish)
    connections[fish] = {}

    local function watchLabel(label, key)
        if not label then return end
        table.insert(connections[fish],
            label:GetPropertyChangedSignal("Text"):Connect(function()
                textCache[fish][key] = label.Text
                rebuildDrawText(fish)
            end)
        )
    end

    watchLabel(nameLabel,     "name")
    watchLabel(mutationLabel, "mutation")
end

local function cleanupFishDraw(fish)
    local esp = espDrawCache[fish]
    if esp then
        esp.name:Remove()
        esp.mutationLabel:Remove()
        esp.mutationName:Remove()
        esp.mutationAmount:Remove()
        esp.tracer:Remove()
        espDrawCache[fish] = nil
    end
    if connections[fish] then
        for _, c in ipairs(connections[fish]) do c:Disconnect() end
        connections[fish] = nil
    end
    textCache[fish] = nil
end

RunService.RenderStepped:Connect(function()
    if not ESPState.FishName and not ESPState.FishMutation then
        for _, esp in pairs(espDrawCache) do
            esp.name.Visible          = false
            esp.mutationLabel.Visible = false
            esp.mutationName.Visible  = false
            esp.mutationAmount.Visible = false
            esp.tracer.Visible        = false
        end
        return
    end

    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local mousePos = UserInputService:GetMouseLocation()

    for _, fish in ipairs(fishFolderDraw:GetChildren()) do
        if not espDrawCache[fish] then
            espDrawCache[fish] = {
                name          = createDrawText(Color3.new(1, 1, 1)),
                mutationLabel = createDrawText(Color3.new(1, 1, 1)),
                mutationName  = createDrawText(Color3.new(1, 1, 1)),
                mutationAmount = createDrawText(Color3.new(1, 1, 1)),
                tracer        = createDrawLine(Color3.new(1, 1, 1)),
            }
            hookFishDraw(fish)
        end
    end

    for fish, esp in pairs(espDrawCache) do
        if not fish.Parent then
            cleanupFishDraw(fish)
            continue
        end

        local targetPart = fish:FindFirstChild("Head") or fish:FindFirstChild("RootPart")
        if not targetPart then
            esp.name.Visible          = false
            esp.mutationLabel.Visible = false
            esp.mutationName.Visible  = false
            esp.mutationAmount.Visible = false
            esp.tracer.Visible        = false
            continue
        end

        local data = textCache[fish]
        if not data then continue end

        local dist = (root.Position - targetPart.Position).Magnitude
        if dist > getgenv().ESPSettings.MaxDistance then
            esp.name.Visible          = false
            esp.mutationLabel.Visible = false
            esp.mutationName.Visible  = false
            esp.mutationAmount.Visible = false
            esp.tracer.Visible        = false
            continue
        end

        local fishMod    = fishLookup[data.name]
        local fishRarity = "Common"
        if fishMod then
            local ok, modData = pcall(require, fishMod)
            if ok and modData and modData.rarity then fishRarity = modData.rarity end
        end
        if not getgenv().ESPSettings.Rarities[fishRarity] then
            esp.name.Visible          = false
            esp.mutationLabel.Visible = false
            esp.mutationName.Visible  = false
            esp.mutationAmount.Visible = false
            esp.tracer.Visible        = false
            continue
        end

        local pos, visible = camera:WorldToViewportPoint(targetPart.Position)
        if not visible then
            esp.name.Visible          = false
            esp.mutationLabel.Visible = false
            esp.mutationName.Visible  = false
            esp.mutationAmount.Visible = false
            esp.tracer.Visible        = false
            continue
        end

        if ESPState.FishName then
            esp.name.Position = Vector2.new(pos.X, pos.Y)
            esp.name.Text     = data.name
            esp.name.Color    = getRarityColor(data.name)
            esp.name.Visible  = true
        else
            esp.name.Visible = false
        end

        local mutationText = data.mutation
        local price        = 1
        local mutColor     = Color3.new(1, 1, 1)

        if mutationText ~= "" and mutationText ~= "Shiny" then
            local mutData = getMutationData(mutationText)
            mutColor      = mutData.color or Color3.new(1, 1, 1)
            price         = mutData.priceMultiplier or 1
        else
            mutationText = "None"
            price        = 1
            mutColor     = Color3.new(1, 1, 1)
        end

        if ESPState.FishMutation then
            esp.mutationLabel.Position  = Vector2.new(pos.X - 50, pos.Y + 16)
            esp.mutationLabel.Text      = "Mutation:"
            esp.mutationLabel.Color     = Color3.new(1, 1, 1)
            esp.mutationLabel.Visible   = true

            esp.mutationName.Position   = Vector2.new(pos.X, pos.Y + 16)
            esp.mutationName.Text       = mutationText
            esp.mutationName.Color      = mutColor
            esp.mutationName.Visible    = true

            esp.mutationAmount.Position = Vector2.new(pos.X + 50, pos.Y + 16)
            esp.mutationAmount.Text     = string.format("[x%.1f]", price)
            esp.mutationAmount.Color    = Color3.new(1, 1, 1)
            esp.mutationAmount.Visible  = true
        else
            esp.mutationLabel.Visible  = false
            esp.mutationName.Visible   = false
            esp.mutationAmount.Visible = false
        end

        if getgenv().ESPSettings.Tracers then
            esp.tracer.From    = Vector2.new(mousePos.X, mousePos.Y)
            esp.tracer.To      = Vector2.new(pos.X, pos.Y)
            esp.tracer.Color   = getRarityColor(data.name)
            esp.tracer.Visible = true
        else
            esp.tracer.Visible = false
        end
    end
end)

